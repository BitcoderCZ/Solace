{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Shared": {
    "StaticDataPath": "../../staticdata"
  },
  "Database": {
    "Earth": {
      "UseSqlite": false
    }
  },
  "ObjectStore": {
    "DataDirectory": "data/object_store"
  },
  "Locator": {
    "Port": 8080
  },
  "ApiServer": {
    "Port": 8088,
    "Authentication": {
      "LocalLoginOnly": false,
      "Login": {
        "SoapHeaderValidityMinutes": 1,
        "UserTokenValidityMinutes": 10080,
        "DeviceTokenValidityMinutes": 1,
        "XboxTokenValidityMinutes": 10080
      },
      "XboxLive": {
        "TokenValidityMinutes": 10080
      },
      "PlayfabApi": {
        "EntityTokenValidityMinutes": 1440,
        "SessionTicketValidityMinutes": 1440
      }
    }
  },
  "BuildplateLauncher": {
    "PublicEndPoint": "127.0.0.1",
    "BaseInstancePublicPort": 19132,
    "FountainBridgeJarName": "fountain-{{version}}-SNAPSHOT-jar-with-dependencies.jar",
    "FabricJarName": "fabric-server-mc.1.20.4-loader.0.15.10-launcher.1.0.1.jar",
    "ConnectorPluginJarName": "buildplate-connector-plugin-{{version}}-SNAPSHOT-jar-with-dependencies.jar"
  },
  "TileRenderer": {
    "TileSource": {
      "MapTilerApiKey": "",
      "TileDatabaseConnectionString": ""
    }
  },
  "AdminPanel": {
    "Port": 5000,
    "EnableAdminPanelBuildplatePreview": true
  }
}