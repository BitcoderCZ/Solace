{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Aspire.Hosting.Dcp": "Warning"
    }
  },
  "Shared": {
    "StaticDataPath": "staticdata",
    "UseSqlite": false
  },
  "ObjectStore": {
    "DataDirectory": "data/object_store"
  },
  "Locator": {
    "Port": 8080
  },
  "ApiServer": {
    "Port": 8088,
    "Authentication":
    {
      "LocalLoginOnly": false,
      "Login": {
        "SoapHeaderValidityMinutes": 1,
        "UserTokenValidityMinutes": 10080,
        "DeviceTokenValidityMinutes": 1,
        "XboxTokenValidityMinutes": 10080
      },
      "XboxLive": {
        "TokenValidityMinutes": 10080
      },
      "PlayfabApi": {
        "EntityTokenValidityMinutes": 1440,
        "SessionTicketValidityMinutes": 1440
      }
    }
  }
}
