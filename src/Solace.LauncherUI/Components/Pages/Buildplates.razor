@page "/Buildplates"
@using HomagGroup.Blazor3D.Enums
@using HomagGroup.Blazor3D.Geometires
@using HomagGroup.Blazor3D.Lights
@using HomagGroup.Blazor3D.Maths
@using HomagGroup.Blazor3D.Objects
@using HomagGroup.Blazor3D.Scenes
@using HomagGroup.Blazor3D.Settings
@using HomagGroup.Blazor3D.Viewers
@using Microsoft.AspNetCore.Authorization
@using System.Security.Claims
@using System.Diagnostics
@using Microsoft.EntityFrameworkCore
@using Serilog
@using Solace.Buildplate.Model
@using Solace.BuildplateImporter
@using Solace.BuildplateRenderer
@using Solace.DB
@using Solace.EventBus.Client
@using Solace.LauncherUI.Data
@using Solace.LauncherUI.Programs
@using Solace.LauncherUI.Utils
@using Solace.ObjectStore.Client
@attribute [Authorize(Policy = Permissions.ViewBuildplates)]
@rendermode InteractiveServer
@inject AuthenticationStateProvider AuthStateProvider
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject ServerManager ServerManager
@inject IJSRuntime JSRuntime
@inject IDbContextFactory<EarthDbContext> EarthDbFactory

<PageTitle>Buildplates - Solace</PageTitle>

<div class="container-fluid mt-4">
    <div class="d-flex flex-wrap justify-content-between align-items-center mb-4 gap-3">
        <div class="d-flex align-items-center">
            <h2 class="mb-0">Buildplates</h2>
            <span class="badge bg-secondary rounded-pill ms-2">
                @(_totalBuildplateCount?.ToString() ?? "?")
            </span>
        </div>

        <div class="input-group" style="max-width: 400px;">
            <input type="text" class="form-control" placeholder="Search by name..." @bind="_searchTerm" @bind:event="oninput" @onkeyup="HandleSearchKeyPress" />
            <button class="btn btn-outline-secondary" type="button" @onclick="DoSearch">
                <i class="bi bi-search"></i> Search
            </button>
        </div>

        @if (HasPermission(Permissions.ManageBuildplates))
        {
            <a href="/Admin/ImportBuildplate" class="btn btn-primary fw-bold">
                <i class="bi bi-plus-lg"></i> Import Buildplate(s)
            </a>
        }
    </div>

    <div class="row g-4">
        @if (_buildplates == null || !_buildplates.Any())
        {
            <div class="col-12">
                <div class="alert alert-info">
                    @(string.IsNullOrWhiteSpace(_searchTerm)
                        ? "No buildplates found. Try importing one!"
                        : "No buildplates match your search.")
                </div>
            </div>
        }
        else
        {
            @foreach (var bp in _buildplates)
            {
                float scaleVal = 1f / bp.BlocksPerMeter;
                string displayScale = scaleVal >= 1
                ? $"1:{scaleVal:0.##}"
                : $"{(1 / scaleVal):0.##}:1";

                <div class="col-12 col-md-6 col-lg-4 col-xl-3" @key="bp.Id">
                    <div class="card h-100 shadow-sm @(bp.IsBusy ? "opacity-50" : "")">
                        <BuildplatePreview BuildplateId="@bp.Id" IsTemplate=true Size="@bp.Size" BlocksPerMeter="@bp.BlocksPerMeter" IsNight="@bp.IsNight" ResourcePackManager="@_resourcePackManager" />

                        <div class="card-body">
                            @if (!string.IsNullOrEmpty(bp.ErrorMessage))
                            {
                                <div class="alert alert-danger alert-dismissible fade show small py-2" role="alert">
                                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                                    @bp.ErrorMessage
                                    <button type="button" class="btn-close small" style="padding: 0.75rem" @onclick="() => bp.ErrorMessage = null"></button>
                                </div>
                            }
                            <div class="mb-3">
                                <label class="form-label visually-hidden">Buildplate Name</label>
                                <input type="text" minlength="1" maxlength="100" class="form-control fw-bold border-0 bg-light" @bind="bp.Name" @bind:event="oninput" disabled="@(!HasPermission(Permissions.ManageBuildplates) || bp.IsBusy)" />
                            </div>

                            <div class="row text-muted small">
                                <div class="col-6 mb-2">
                                    <span class="d-block fw-bold text-uppercase">Size</span>
                                    <span>@(bp.Size)x@(bp.Size)</span>
                                </div>
                                <div class="col-6 mb-2">
                                    <span class="d-block fw-bold text-uppercase">Blocks per meter</span>
                                    <input type="number" min="1" max="100" class="form-control form-control-sm border-0 bg-light" @bind="bp.BlocksPerMeter" @bind:event="oninput" disabled="@(!HasPermission(Permissions.ManageBuildplates) || bp.IsBusy)" />
                                </div>
                                <div class="col-12">
                                    <span class="d-block fw-bold text-uppercase">Offset</span>
                                    <span>@bp.Offset</span>
                                </div>
                            </div>
                        </div>

                        @if (HasPermission(Permissions.ManageBuildplates))
                        {
                            <div class="card-footer bg-transparent border-top-0 pb-3 d-flex flex-column gap-2">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <button class="btn btn-outline-danger btn-sm" @onclick="() => RequestDelete(bp)" disabled="@bp.IsBusy">
                                        Delete
                                    </button>

                                    @if (bp.IsDirty || bp.IsSaving)
                                    {
                                        <button class="btn btn-success btn-sm fw-bold" @onclick="() => SaveBuildplate(bp)" disabled="@bp.IsBusy">
                                            @if (bp.IsSaving)
                                            {
                                                <span class="spinner-border spinner-border-sm me-1"></span>
                                            }
                                            Save
                                        </button>
                                    }
                                </div>

                                <div class="d-flex gap-2">
                                    <button class="btn btn-outline-primary btn-sm w-100 fw-bold" @onclick="() => RegeneratePreview(bp)" disabled="@bp.IsBusy">
                                        @if (bp.IsRegeneratingPreview)
                                        {
                                            <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                                            <span>Regenerating...</span>
                                        }
                                        else
                                        {
                                            <i class="bi bi-gear-fill me-1"></i>
                                            <span>Regenerate</span>
                                        }
                                    </button>

                                    <button class="btn btn-outline-secondary btn-sm w-100 fw-bold" @onclick="() => RequestExport(bp)" disabled="@bp.IsBusy">
                                        <i class="bi bi-download me-1"></i>
                                        <span>Export</span>
                                    </button>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        }
    </div>

    @if (TotalPages > 1)
    {
        <div class="d-flex justify-content-center mt-5 mb-3">
            <nav aria-label="Buildplate pagination">
                <ul class="pagination">
                    <li class="page-item @(_currentPage == 1 ? "disabled" : "")">
                        <button class="page-link" @onclick="PrevPage" tabindex="-1">Previous</button>
                    </li>
                    <li class="page-item disabled">
                        <span class="page-link text-dark">Page @_currentPage of @TotalPages</span>
                    </li>
                    <li class="page-item @(_currentPage == TotalPages ? "disabled" : "")">
                        <button class="page-link" @onclick="NextPage">Next</button>
                    </li>
                </ul>
            </nav>
        </div>
    }
</div>

@if (_showDeleteModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Confirm Deletion</h5>
                    <button type="button" class="btn-close" @onclick="CancelDelete"></button>
                </div>
                <div class="modal-body">
                    <p>Are you sure you want to delete <strong>@_bpToDelete?.Name</strong>?</p>

                    <div class="form-check form-switch mt-3">
                        <input class="form-check-input" type="checkbox" id="removeTemplateCheckbox" @bind="_removeTemplateFromPlayers" />
                        <label class="form-check-label text-danger" for="removeTemplateToggle">
                            Also remove this template from all players inventories
                        </label>
                    </div>
                </div>
                <div class="modal-footer bg-light">
                    <button type="button" class="btn btn-secondary" @onclick="CancelDelete" disabled="@_isDeleting">Cancel</button>
                    <button type="button" class="btn btn-danger" @onclick="ConfirmDelete" disabled="@_isDeleting" style="min-width: 100px;">
                        @if (_isDeleting)
                        {
                            <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                            <span>Deleting...</span>
                        }
                        else
                        {
                            <span>Delete</span>
                        }
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@if (!string.IsNullOrEmpty(_deleteErrorMessage))
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.6); z-index: 1060;">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-danger shadow-lg">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title"><i class="bi bi-exclamation-octagon-fill me-2"></i>Deletion Failed</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CloseErrorModal"></button>
                </div>
                <div class="modal-body">
                    <p>An error occurred while trying to delete <strong>@_bpToDelete?.Name</strong>:</p>
                    <div class="alert alert-light border small text-break">
                        @_deleteErrorMessage
                    </div>
                    <p class="mb-0">Please try again or report the issue if it persists.</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseErrorModal">Close</button>
                    <button type="button" class="btn btn-danger" @onclick="ConfirmDelete">
                        <i class="bi bi-arrow-clockwise me-1"></i> Retry
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@if (_showExportModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Export Buildplate</h5>
                    <button type="button" class="btn-close" @onclick="CancelExport" disabled="@_isExporting"></button>
                </div>
                <div class="modal-body">
                    <p>Select export format for <strong>@_exportBp?.Name</strong>:</p>

                    <select class="form-select mb-4" @bind="_exportFormat" disabled="@_isExporting">
                        <option value="Solace">Solace/Vienna</option>
                        <option value="Earth">Project Earth</option>
                    </select>

                    @if (_isExporting)
                    {
                        <div class="progress mb-2" style="height: 20px;">
                            <div class="progress-bar progress-bar-striped progress-bar-animated" role="progressbar" style="width: @_exportProgress%;" aria-valuenow="@_exportProgress" aria-valuemin="0" aria-valuemax="100">@_exportProgress%</div>
                        </div>
                        <p class="text-center text-muted small mb-0">Generating file...</p>
                    }

                    @if (!string.IsNullOrEmpty(_exportErrorMessage))
                    {
                        <div class="alert alert-danger alert-dismissible fade show small py-2 mt-2 mb-0" role="alert">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i>
                            @_exportErrorMessage
                            <button type="button" class="btn-close small" style="padding: 0.75rem" @onclick="() => _exportErrorMessage = null"></button>
                        </div>
                    }
                </div>
                <div class="modal-footer bg-light">
                    <button type="button" class="btn btn-secondary" @onclick="CancelExport" disabled="@_isExporting">Cancel</button>
                    <button type="button" class="btn btn-primary" @onclick="ConfirmExport" disabled="@_isExporting" style="min-width: 100px;">
                        @if (_isExporting)
                        {
                            <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                            <span>Exporting...</span>
                        }
                        else
                        {
                            <span>Export</span>
                        }
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private ClaimsPrincipal? _user;
    private List<Buildplate> _buildplates = new();

    private ResourcePackManager _resourcePackManager = null!;

    private int? _totalBuildplateCount;

    // Search and Pagination State
    private string _searchTerm = string.Empty;
    private int _currentPage = 1;
    private int _pageSize = 8;
    private int _totalItems = 0;
    private int TotalPages => Math.Max(1, (int)Math.Ceiling((double)_totalItems / _pageSize));

    // Modal State
    private bool _showDeleteModal = false;
    private bool _isDeleting = false;
    private Buildplate? _bpToDelete;
    private bool _removeTemplateFromPlayers = false;
    private string? _deleteErrorMessage;

    // Export Modal State
    private bool _showExportModal = false;
    private bool _isExporting = false;
    private Buildplate? _exportBp;
    private string _exportFormat = "Solace";
    private int _exportProgress = 0;
    private string? _exportErrorMessage;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        _user = authState.User;

        _resourcePackManager = await ResourcePackManagerSingleton.GetResourcePackManagerAsync();

        await LoadBuildplates();
    }

    private async Task LoadBuildplates()
    {
        try
        {
            int skip = (_currentPage - 1) * _pageSize;
            string? searchFilter = string.IsNullOrWhiteSpace(_searchTerm) ? null : _searchTerm;

            await using var earthDb = await EarthDbFactory.CreateDbContextAsync();
            var query = (IQueryable<DB.Models.Global.TemplateBuildplateEF>)earthDb.TemplateBuildplates;

            if (!string.IsNullOrWhiteSpace(searchFilter))
            {
                query = query.Where(buildplate => EF.Functions.Like(buildplate.Name, $"%{searchFilter}%"));
            }

            _totalItems = await query.CountAsync();

            var buildplates = await query
                .Skip(skip)
                .Take(_pageSize)
                .ToListAsync();

            if (string.IsNullOrWhiteSpace(searchFilter))
            {
                _totalBuildplateCount = _totalItems;
            }

            _buildplates.Clear(); // Clear current page data
            _buildplates.EnsureCapacity(buildplates.Count);

            foreach (var dbBuildplate in buildplates)
            {
                Debug.Assert(dbBuildplate is not null);

                var buildplate = new Buildplate()
                {
                    Id = dbBuildplate.Id,
                    Name = dbBuildplate.Name,
                    Size = dbBuildplate.Size,
                    Offset = dbBuildplate.Offset,
                    BlocksPerMeter = dbBuildplate.Scale,
                    IsNight = dbBuildplate.Night,
                    ServerDataObjectId = dbBuildplate.ServerDataObjectId,
                    PreviewObjectId = dbBuildplate.PreviewObjectId,
                };

                buildplate.AcceptChanges();

                _buildplates.Add(buildplate);
            }
        }
        catch (Exception ex)
        {
            Log.Error($"Could not connect to earth db: {ex}");
        }
    }

    // --- Search Handlers ---
    private async Task DoSearch()
    {
        _currentPage = 1; // Reset to page 1 on new search
        await LoadBuildplates();
    }

    private async Task HandleSearchKeyPress(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await DoSearch();
        }
    }

    // --- Pagination Handlers ---
    private async Task PrevPage()
    {
        if (_currentPage > 1)
        {
            _currentPage--;
            await LoadBuildplates();
        }
    }

    private async Task NextPage()
    {
        if (_currentPage < TotalPages)
        {
            _currentPage++;
            await LoadBuildplates();
        }
    }

    private async Task RegeneratePreview(Buildplate bp)
    {
        if (!HasPermission(Permissions.ManageBuildplates))
        {
            return;
        }

        bp.IsRegeneratingPreview = true;
        bp.ErrorMessage = null;

        if (!await ServerManager.EnsureComponentsOnline(EventBusServer.ExeName, ObjectStoreServer.ExeName, BuildplateLauncher.ExeName))
        {
            bp.ErrorMessage = "The server must be running.";
            bp.IsRegeneratingPreview = false;
            return;
        }

        try
        {
            await using var importer = await Importer.CreateFromSettings(Settings.Instance, await EarthDbFactory.CreateDbContextAsync(), Log.Logger, ownsEarthDb: true);

            if (!await importer.RegenerateTemplatePreviewAsync(bp.Id, default))
            {
                bp.ErrorMessage = "Failed to regenerate preview, check Launcher logs for details.";
                return;
            }

            Log.Information($"Successfully regenerated preview for buildplate {bp.Id}");
        }
        catch (Exception ex)
        {
            Log.Error($"Failed to regenerate preview: {ex}");
            bp.ErrorMessage = "Failed to regenerate preview. Try again?";
        }
        finally
        {
            bp.IsRegeneratingPreview = false;
        }
    }

    private async Task SaveBuildplate(Buildplate bp)
    {
        if (!HasPermission(Permissions.ManageBuildplates))
        {
            return;
        }

        bp.IsSaving = true;
        bp.ErrorMessage = null;

        bp.Name = bp.Name.Trim();

        if (string.IsNullOrEmpty(bp.Name))
        {
            bp.ErrorMessage = "Name cannot be empty.";
            bp.IsSaving = false;
            return;
        }

        try
        {
            await using var earthDb = await EarthDbFactory.CreateDbContextAsync();

            var template = await earthDb.TemplateBuildplates
                .AsTracking()
                .FirstAsync(template => template.Id == bp.Id);

            template.Name = bp.Name;
            template.Scale = bp.BlocksPerMeter;

            await earthDb.SaveChangesAsync();

            await Task.Delay(250);

            bp.AcceptChanges();
            Log.Information($"Successfully updated buildplate {bp.Id}");
        }
        catch (Exception ex)
        {
            Log.Error($"Failed to save buildplate '{bp.Id}'': {ex}");
            bp.ErrorMessage = "Failed to save. Try again?";
        }
        finally
        {
            bp.IsSaving = false;
        }
    }

    private void RequestDelete(Buildplate bp)
    {
        _bpToDelete = bp;
        _removeTemplateFromPlayers = false;
        _deleteErrorMessage = null;
        _showDeleteModal = true;
    }

    private void CancelDelete()
    {
        _bpToDelete = null;
        _removeTemplateFromPlayers = false;
        _deleteErrorMessage = null;
        _showDeleteModal = false;
    }

    private async Task ConfirmDelete()
    {
        _deleteErrorMessage = null;

        if (!await ServerManager.EnsureComponentsOnline(ObjectStoreServer.ExeName))
        {
            _deleteErrorMessage = "The server must be running to delete buildplates.";
            return;
        }

        if (_bpToDelete is not null && HasPermission(Permissions.ManageBuildplates))
        {
            try
            {
                _isDeleting = true;
                StateHasChanged();

                await using var importer = await Importer.CreateFromSettings(Settings.Instance, await EarthDbFactory.CreateDbContextAsync(), Log.Logger, createEventBus: false, ownsEarthDb: true);

                if (!await importer.RemoveTemplateAsync(_bpToDelete.Id, _removeTemplateFromPlayers, default))
                {
                    _deleteErrorMessage = "Failed to delete buildplate, check Launcher logs for details.";
                    return;
                }

                await LoadBuildplates();
                CancelDelete();
            }
            catch (Exception ex)
            {
                Log.Error(ex, "Failed to delete buildplate");
                _deleteErrorMessage = $"Failed to delete the buildplate: {ex.Message}";
            }
            finally
            {
                _isDeleting = false;
            }
        }
    }

    private void CloseErrorModal()
    {
        _deleteErrorMessage = null;
    }

    private void RequestExport(Buildplate bp)
    {
        _exportBp = bp;
        _exportFormat = "Solace";
        _exportProgress = 0;
        _exportErrorMessage = null;
        _showExportModal = true;
    }

    private void CancelExport()
    {
        if (_isExporting)
        {
            return;
        }

        _showExportModal = false;
        _exportBp = null;
    }

    private async Task ConfirmExport()
    {
        if (_exportBp is null)
        {
            return;
        }

        _isExporting = true;
        _exportProgress = 0;
        _exportErrorMessage = null;

        for (int i = 0; i <= 100; i += 20)
        {
            _exportProgress = i;
            StateHasChanged();
            await Task.Delay(400);
        }

        try
        {
            byte[] fileData = System.Text.Encoding.UTF8.GetBytes($"Mock data for buildplate: {_exportBp.Name} in format {_exportFormat}");

            using var fileStream = new MemoryStream(fileData);
            using var streamRef = new DotNetStreamReference(stream: fileStream);

            string extension = _exportFormat == "Solace" ? "zip" : "json";
            string fileName = $"{_exportBp.Name.Replace(" ", "_")}_export.{extension}";

            await JSRuntime.InvokeVoidAsync("downloadFileFromStream", fileName, streamRef);

            Log.Information($"Successfully triggered download for {fileName}");

            _showExportModal = false;
            _exportBp = null;
        }
        catch (Exception ex)
        {
            Log.Error($"Failed to download buildplate file: {ex.Message}");
            _exportErrorMessage = $"Export failed: {ex.Message}";
        }
        finally
        {
            _isExporting = false;
        }
    }

    private bool HasPermission(string permission)
        => _user?.HasPermission(permission) ?? false;

    public sealed class Buildplate
    {
        public required Guid Id { get; set; }

        public required string Name { get; set; }
        public int BlocksPerMeter { get; set; }
        public int Size { get; set; }
        public int Offset { get; set; }
        public bool IsNight { get; set; }

        public required string ServerDataObjectId { get; set; }
        public required string PreviewObjectId { get; set; }

        // Change Tracking
        private string? _originalName;
        private int _originalBlocksPerMeter = -1;

        public bool IsDirty => Name != _originalName || BlocksPerMeter != _originalBlocksPerMeter;

        // UI State
        public bool IsSaving { get; set; }
        public bool IsRegeneratingPreview { get; set; }

        public bool IsBusy => IsSaving || IsRegeneratingPreview;

        public string? ErrorMessage { get; set; }

        public void AcceptChanges()
        {
            _originalName = Name;
            _originalBlocksPerMeter = BlocksPerMeter;
        }
    }
}